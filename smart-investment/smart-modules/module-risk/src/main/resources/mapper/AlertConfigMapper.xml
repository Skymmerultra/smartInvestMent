<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smart.investment.module.risk.mapper.AlertConfigMapper">

    <select id="selectByUserIdAndRiskType" resultType="com.smart.investment.module.risk.entity.AlertConfig">
        SELECT * FROM alert_config WHERE user_id = #{userId} AND risk_type = #{riskType}
    </select>

    <select id="selectByUserId" resultType="com.smart.investment.module.risk.entity.AlertConfig">
        SELECT * FROM alert_config WHERE user_id = #{userId} ORDER BY risk_type
    </select>

    <select id="selectActiveConfigs" resultType="com.smart.investment.module.risk.entity.AlertConfig">
        SELECT * FROM alert_config WHERE is_active = 1
    </select>

</mapper>